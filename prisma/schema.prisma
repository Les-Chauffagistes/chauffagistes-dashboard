generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
  binaryTargets = ["native", "darwin"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model lnurl_auth {
  k1         String    @id
  status     String
  created_at DateTime? @default(now()) @db.Timestamp(6)
  user_id    BigInt?
}

/// This table has subclasses and requires additional setup for migrations. Visit https://pris.ly/d/table-inheritance for more info.
/// The underlying table does not contain a valid unique identifier and can therefore currently not be handled by Prisma Client.
model worker_stats_raw {
  worker_id      String
  timestamp      DateTime @default(now()) @db.Timestamptz(6)
  avg_hashrate1m BigInt?
  avg_hashrate5m BigInt?
  avg_hashrate1h BigInt?
  avg_hashrate1d BigInt?
  avg_hashrate7d BigInt?
  avg_weight     Decimal? @db.Decimal(6, 3)
  user           String?

  @@index([timestamp(sort: Desc)])
  @@index([user, worker_id, timestamp(sort: Desc)])
  @@ignore
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model workernames {
  workername  String
  user        BigInt
  status      String   @default("pending")
  created_at  DateTime @default(now()) @db.Date
  btc_address String
  code        String
  users       users    @relation(fields: [user], references: [id], onDelete: Cascade, map: "fk workernames.user")

  @@id([workername, user, btc_address])
}

model discord_users {
  id           String @id
  discord_name String
  user_id      BigInt
  users        users  @relation(fields: [user_id], references: [id], onDelete: Cascade, map: "fk dc_users.users")
}

model ln_users {
  id      BigInt  @id(map: "users_pkey") @default(autoincrement())
  ln_key  String?
  user_id BigInt?
  users   users?  @relation(fields: [user_id], references: [id], onDelete: Cascade, map: "ln_users_users_id_fk")
}

model users {
  id            BigInt          @id(map: "users_pkey1") @default(autoincrement())
  pseudo        String?
  created_at    DateTime        @default(now()) @db.Date
  address       String?
  discord_users discord_users[]
  ln_users      ln_users[]
  workernames   workernames[]
}
